# Django Settings
SECRET_KEY=your-django-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,wordastra.onrender.com

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/wordastra

# Clerk Authentication
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here
CLERK_FRONTEND_API=your-frontend-api.clerk.accounts.dev

# Google OAuth Settings (not used with Clerk)
# GOOGLE_CLIENT_ID=your-google-client-id-here
# GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# GitHub OAuth Settings (not used with Clerk)
# GITHUB_CLIENT_ID=your-github-client-id-here
# GITHUB_CLIENT_SECRET=your-github-client-secret-here

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:8000,https://wordastra.onrender.com
