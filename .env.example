# Django Settings
SECRET_KEY=your-django-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.onrender.com,localhost,127.0.0.1

# PostgreSQL Database (required on Render)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set to True only for local SQLite development (disables SSL requirement)
DISABLE_SSL=False

# Clerk Authentication
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here
CLERK_FRONTEND_API=your-frontend-api.clerk.accounts.dev

# CORS Settings
CORS_ALLOWED_ORIGINS=https://yourdomain.onrender.com,http://localhost:8000,http://127.0.0.1:8000
